# ===========================================
# CONFIGURACION APLICACION
# Plantilla Gobierno Digital Chile
# ===========================================

# Ambiente
NODE_ENV=development
PORT=3000
APP_NAME="Aplicacion Gobierno Digital"
APP_VERSION=1.0.0

# ===========================================
# CLAVEUNICA - Autenticacion Estado de Chile
# Documentacion: https://digital.gob.cl/
# ===========================================
CLAVEUNICA_CLIENT_ID=
CLAVEUNICA_CLIENT_SECRET=
CLAVEUNICA_REDIRECT_URI=http://localhost:3000/auth/callback
CLAVEUNICA_ISSUER=https://accounts.claveunica.gob.cl/openid

# Scopes disponibles: openid run name email
CLAVEUNICA_SCOPES=openid run name

# ===========================================
# BASE DE DATOS
# PostgreSQL recomendado para cumplimiento normativo
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_gobierno
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ===========================================
# REDIS - Cache y Sesiones
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
SESSION_TTL=3600

# ===========================================
# SEGURIDAD - Ley 21.663
# ===========================================

# JWT para tokens internos
JWT_SECRET=cambiar-en-produccion-minimo-32-caracteres
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Encriptacion de datos sensibles (AES-256)
ENCRYPTION_KEY=cambiar-en-produccion-32-caracteres

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# INTEROPERABILIDAD - PISEE 2.0
# Plataforma Integracion Servicios Estado
# ===========================================
PISEE_API_URL=https://api.pisee.gob.cl/v2
PISEE_API_KEY=
PISEE_INSTITUTION_ID=

# ===========================================
# SALUD DIGITAL - HL7 FHIR R4
# Para modulos de salud
# ===========================================
FHIR_SERVER_URL=https://fhir.minsal.cl/r4
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=

# Terminologias
SNOMED_CT_VERSION=2024-01-01
CIE10_VERSION=2022

# ===========================================
# AUDITORIA Y LOGGING
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=365

# ===========================================
# ALMACENAMIENTO
# Para documentos electronicos
# ===========================================
STORAGE_TYPE=local
STORAGE_PATH=./storage
# Para S3/MinIO
# STORAGE_TYPE=s3
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ===========================================
# NOTIFICACIONES
# ===========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@institucion.gob.cl
