{
  "name": "plantilla-gobierno-digital-chile",
  "version": "1.0.0",
  "description": "Plantilla de aplicaciones modulares CRUD para Gobierno Digital y Salud Chile - Cumple Ley 21.180, 21.663, 21.668, 21.541",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "generate:module": "plop module",
    "generate:fhir-resource": "plop fhir-resource",
    "docs:api": "swagger-jsdoc -d swagger.config.js -o docs/openapi.json src/**/*.ts",
    "audit:security": "npm audit --audit-level=high",
    "audit:owasp": "tsx scripts/owasp-check.ts",
    "validate:fhir": "tsx scripts/validate-fhir.ts",
    "prepare": "husky install"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "fhir-kit-client": "^1.9.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jose": "^5.2.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-forge": "^1.3.1",
    "openid-client": "^5.6.4",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.1",
    "uuid": "^9.0.1",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.16",
    "@types/node-forge": "^1.3.11",
    "@types/uuid": "^9.0.8",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-security": "^2.1.0",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.2",
    "plop": "^4.0.1",
    "prettier": "^3.2.5",
    "prisma": "^5.10.0",
    "swagger-jsdoc": "^6.2.8",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "gobierno-digital",
    "chile",
    "claveunica",
    "fhir",
    "hl7",
    "minsal",
    "interoperabilidad",
    "salud-digital",
    "ley-21180",
    "ley-21663"
  ],
  "license": "MIT"
}
